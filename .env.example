# ── App ──
NODE_ENV=development
PORT=3000

# ── PostgreSQL ──
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=aijobfetcher
DB_PASSWORD=changeme
DB_DATABASE=aijobfetcher

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── JWT ──
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_EXPIRATION=3600

# ── MinIO / S3 ──
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=resumes
MINIO_USE_SSL=false

# ── Embedding API (Gemini) ──
GEMINI_API_KEY=your-gemini-api-key
GEMINI_EMBEDDING_MODEL=text-embedding-004

# ── Email (SMTP) ──
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASS=changeme
SMTP_FROM=AI Job Fetcher <noreply@example.com>

# ── Scraping ──
SCRAPE_CRON=0 */6 * * *
SCRAPE_RATE_LIMIT_PER_DOMAIN=2
SCRAPE_USER_AGENT=AIJobFetcher/1.0 (+https://example.com/bot)
